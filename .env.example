# ---------------------------------------------------------------------------
# LHP Staff ID & QR Verification — environment template
# Copy to `.env` and fill in real values. This file is safe to commit.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (Neon, Supabase, Railway, or local).
# Prisma v7: this is the ONLY connection string required — no directUrl.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Secret used to derive session token hashes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-32-byte-random-hex-string"

# Bootstrap administrator, created by `npm run db:seed`.
# Without this the very first admin cannot exist, since admins create admins.
ADMIN_EMAIL="admin@lhp.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# Public base URL — used to build the QR verification URL.
NEXT_PUBLIC_APP_URL="http://localhost:3001"
