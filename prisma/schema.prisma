// ---------------------------------------------------------------------------
// LHP — Staff ID & QR Verification System
// Authoritative Prisma schema (Prisma v7 style: single DATABASE_URL, no directUrl)
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma v7: the connection URL lives in `prisma.config.ts` (for the CLI) and is
// supplied to PrismaClient via a driver adapter (see src/lib/prisma.ts).
// DATABASE_URL remains the single source of truth for both.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  STAFF
}

enum StaffStatus {
  ACTIVE
  DISENGAGED
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

/// A login account. Every Staff record is backed by exactly one User.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  /// Forces the staff member through the password-reset flow on next login.
  /// Set on account creation and on every DISENGAGED -> ACTIVE reactivation.
  mustResetPw  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staff       Staff?
  sessions    Session[]
  auditWrites AuditLog[] @relation("AuditChangedBy")

  @@index([role])
}

/// DB-backed, revocable session. `id` is an opaque token id — specifically the
/// HMAC-SHA256 of the raw cookie value, so a database leak never yields a
/// usable session cookie.
model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Staff
// ---------------------------------------------------------------------------

model Staff {
  id String @id @default(cuid())

  /// Human-facing staff identifier, e.g. "STF-000247". Treated as immutable
  /// after creation — the QR verification URL is derived from it.
  stfId       String      @unique
  name        String
  photoUrl    String?
  status      StaffStatus @default(ACTIVE)
  dateEngaged DateTime

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roles     StaffRole[]
  venues    StaffVenue[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([name])
}

model Role {
  id    String      @id @default(cuid())
  name  String      @unique
  staff StaffRole[]
}

model Venue {
  id    String       @id @default(cuid())
  name  String       @unique
  staff StaffVenue[]
}

/// Many-to-many: Staff <-> Role
model StaffRole {
  staffId String
  roleId  String

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([staffId, roleId])
  @@index([roleId])
}

/// Many-to-many: Staff <-> Venue
model StaffVenue {
  staffId String
  venueId String

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([staffId, venueId])
  @@index([venueId])
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Append-only record of every state-changing admin action on a Staff record.
model AuditLog {
  id        String   @id @default(cuid())
  staffId   String
  field     String
  oldValue  String?
  newValue  String?
  changedBy String?
  timestamp DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  actor User? @relation("AuditChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([staffId, timestamp])
}
